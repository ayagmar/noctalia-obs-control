#!/usr/bin/env bash

set -euo pipefail

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
script_js="$script_dir/obsctl.js"

node_bin=""

if command -v node >/dev/null 2>&1; then
  node_bin="$(command -v node)"
elif [ -x "${HOME:-}/.local/share/mise/shims/node" ]; then
  node_bin="${HOME}/.local/share/mise/shims/node"
elif command -v mise >/dev/null 2>&1; then
  node_bin="$(mise which node 2>/dev/null || true)"
fi

if [ -z "$node_bin" ] || [ ! -x "$node_bin" ]; then
  echo "obsctl: node runtime not found in PATH" >&2
  exit 1
fi

exec "$node_bin" "$script_js" "$@"
